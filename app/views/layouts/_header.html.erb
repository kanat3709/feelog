<header style="background: rgba(255,255,255,0.85); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(131,116,114,0.1); padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 50;">
  <%= link_to 'Feelog', root_path, style: 'font-family: "Plus Jakarta Sans", sans-serif; font-size: 1.3rem; font-weight: 700; letter-spacing: -0.02em; color: #9C6B7A; text-decoration: none;' %>
  <nav style="display: flex; gap: 1.5rem; align-items: center;">
    <% if user_signed_in? %>
      <%= link_to 'ログアウト', destroy_user_session_path, data: { turbo_method: :delete }, style: 'font-family: "Plus Jakarta Sans", sans-serif; font-size: 0.9rem; color: #837472; text-decoration: none;' %>
    <% else %>
      <%= link_to 'ログイン', new_user_session_path, style: 'font-family: "Plus Jakarta Sans", sans-serif; font-size: 0.9rem; font-weight: 600; color: #9C6B7A; text-decoration: none; background: rgba(156,107,122,0.08); padding: 0.4rem 1rem; border-radius: 2rem;' %>
      <%= link_to '新規登録', new_user_registration_path, style: 'font-family: "Plus Jakarta Sans", sans-serif; font-size: 0.9rem; font-weight: 600; color: #9C6B7A; text-decoration: none; background: rgba(156,107,122,0.08); padding: 0.4rem 1rem; border-radius: 2rem;' %>
    <% end %>
  </nav>
</header>