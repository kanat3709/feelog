<div class="mypage-wrapper">
  <div class="posts-header">
    <div>
      <h1 class="section-title">
        <span class="material-symbols-outlined">favorite</span>
        いいねした投稿
      </h1>
      <p class="page-subtitle">あなたがいいねした旅の記録</p>
    </div>
  </div>

  <% if @liked_posts.empty? %>
    <div class="posts-empty">
        <p class="posts-empty-title">
            <span class="material-symbols-outlined" style="font-size: 22px; color: var(--color-mauve); vertical-align: middle; margin-right: 4px;">favorite</span>
            まだいいねした投稿はありません
        </p>
      <p class="posts-empty-sub">みんなの旅を見て、気になった投稿にいいねしてみましょう！</p>
      <%= link_to 'みんなの旅を見る', public_posts_path, class: 'btn-primary' %>
    </div>
  <% else %>
    <div class="posts-grid">
      <% @liked_posts.each do |post| %>
        <%= link_to public_post_path(post), class: 'post-card' do %>
          <div class="post-card-thumb">
            <% if post.image.attached? %>
              <%= image_tag post.image, class: 'post-card-img', alt: post.title %>
            <% else %>
              <div class="post-card-no-img">
                <span class="material-symbols-outlined">image</span>
              </div>
            <% end %>
          </div>
          <div class="post-card-body">
            <p class="post-card-title"><%= post.title %></p>
            <% if post.place.present? %>
              <p class="post-card-place">
                <span class="material-symbols-outlined">location_on</span>
                <%= post.place %>
              </p>
            <% end %>
            <p class="post-card-author">
              <span class="material-symbols-outlined">person</span>
              <%= post.user.name %>
            </p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>