<% content_for :ogp_title, @post.title %>
<% content_for :ogp_description, @post.memo.presence || "#{@post.title}の旅の記録" %>
<% content_for :ogp_type, "article" %>
<% if @post.image.attached? %>
  <% content_for :ogp_image, url_for(@post.image) %>
<% end %>

<div class="post-detail-wrapper">
  <%= link_to public_posts_path, class: "post-detail-back" do %>
    <span class="material-symbols-outlined">arrow_back</span>
    みんなの旅へ戻る
  <% end %>

  <div class="post-detail-card">
    <% if @post.image.attached? %>
      <div class="post-detail-image-wrap">
        <%= image_tag @post.image, class: "post-detail-image", alt: @post.title %>
      </div>
    <% else %>
      <div class="post-detail-image-placeholder">
        <span class="material-symbols-outlined">image</span>
      </div>
    <% end %>

    <div class="post-detail-body">
      <h1 class="post-detail-title"><%= @post.title %></h1>

      <div class="post-detail-meta">
        <% if @post.place.present? %>
          <span class="post-detail-meta-item">
            <span class="material-symbols-outlined">location_on</span>
            <%= @post.place %>
          </span>
        <% end %>
        <% if @post.visited_at.present? %>
          <span class="post-detail-meta-item">
            <span class="material-symbols-outlined">calendar_today</span>
            <%= @post.visited_at.strftime('%Y年%m月%d日') %>
          </span>
        <% end %>
        <span class="post-detail-meta-item">
          <span class="material-symbols-outlined">person</span>
          <%= @post.user.name %>
        </span>
      </div>

      <% if @post.emotions.any? %>
        <div class="post-detail-emotions">
          <% @post.emotions.each do |emotion| %>
            <span class="post-detail-emotion-chip">
              <i class="ti <%= emotion_icon(emotion.name) %>"></i>
              <%= emotion.name %>
            </span>
          <% end %>
        </div>
      <% end %>

      <% if @post.memo.present? %>
        <div class="post-detail-memo">
          <p class="post-detail-memo-label">
            <span class="material-symbols-outlined">notes</span>
            ひとことメモ
          </p>
          <p class="post-detail-memo-text"><%= @post.memo %></p>
        </div>
      <% end %>

      <div class="post-detail-reactions">
        <%# いいねボタン %>
        <%= render "likes/like_button", post: @post %>

        <%# 行きたい！ボタン %>
        <%= render "wish_lists/wish_button", post: @post %>
      </div>

      <%# 管理者のみ表示される非表示・再表示ボタン %>
      <% if current_user&.admin? %>
        <div class="post-detail-admin">
          <% if @post.hidden? %>
            <%= button_to '再表示する', unhide_post_path(@post), method: :post, class: "btn-unhide" %>
          <% else %>
            <%= button_to 'この投稿を非表示にする', hide_post_path(@post), method: :post, class: "btn-hide",
                data: { turbo_confirm: 'この投稿を一覧から非表示にしますか？' } %>
          <% end %>
        </div>
      <% end %>
      
    </div>
  </div>
</div>