<h2>新規登録</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <%# ユーザー名 %>
  <div class="field">
    <p><%= f.label :name, "ユーザー名" %></p>
    <p><%= f.text_field :name, autocomplete: "name" %></p>
  </div>

  <%# メールアドレス %>
  <div class="field">
    <p><%= f.label :email, "メールアドレス" %></p>
    <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
  </div>

  <%# パスワード %>
  <div class="field">
    <p><%= f.label :password, "パスワード" %></p>
    <% if @minimum_password_length %>
      <p><em>(<%= @minimum_password_length %>文字以上)</em></p>
    <% end %>
    <p><%= f.password_field :password, autocomplete: "new-password" %></p>
  </div>

  <%# パスワード確認 %>
  <div class="field">
    <p><%= f.label :password_confirmation, "パスワード（確認）" %></p>
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div>

  <%# 利用規約同意チェックボックス %>
  <div class="field">
    <%= f.label :terms_of_service do %>
      <%= f.check_box :terms_of_service %>
      <%= link_to '利用規約', terms_path, target: '_blank' %>に同意する
    <% end %>
  </div>

  <div class="actions">
    <%= f.submit "登録する" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
