<style>
  .signup-outer { display: flex; align-items: center; justify-content: center; min-height: calc(100vh - 60px - 80px); padding: 2rem 1.5rem; }
  .signup-grid { display: grid; grid-template-columns: 1fr 1fr; background: rgba(255,255,255,0.65); backdrop-filter: blur(24px); border-radius: 1rem; border: 1px solid rgba(255,255,255,0.5); box-shadow: 0 10px 40px rgba(125,84,79,0.07); width: 100%; max-width: 1000px; overflow: hidden; }
  .signup-img-panel { position: relative; overflow: hidden; }
  @media (max-width: 640px) {
    .signup-outer { padding: 1rem; }
    .signup-grid { grid-template-columns: 1fr; }
    .signup-img-panel { display: none; }
  }
</style>
<div class="signup-outer">
  <div class="signup-grid">

    <%# 左パネル %>
    <div class="signup-img-panel">
      <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAPc5HZR_6fpaVPddVTn5PNtWDCkLq1vyaZUuo_IXjiYGD--zRxiBf9NEBWl4GXuAm85aHqxBhi6MDeUT_ZYaCYMhOp-UxTS1gICci0RTqnHYatZJFsAi2ygbx_PQoNSSphxFsWMnSD2T56rW1EP_2-rQDErUmD8n_pJU7HqotrZLC0VyZO-YILKfD580Nmu6ykL539yp5XD-5cXy1L4GexZAOeMvzvzk80cw6FsBkEGL4wJ2S9p2gdDpIyR-XY9tpS9T6xZAC8w5o" alt="journal" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"/>
      <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(125,84,79,0.6) 0%, rgba(125,84,79,0.15) 60%, transparent 100%);"></div>
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2.5rem;">
        <h2 style="font-size: 1.9rem; font-weight: 700; color: white; line-height: 1.3; margin-bottom: 0.75rem; letter-spacing: -0.02em; font-family: 'Plus Jakarta Sans', sans-serif;">記録を、<br/>物語に。</h2>
        <p style="font-size: 0.9rem; color: rgba(255,255,255,0.85); line-height: 1.7; font-family: 'Plus Jakarta Sans', sans-serif;">日々の旅路を大切に記録し、あなただけの物語を紡いでいきましょう。</p>
      </div>
    </div>

    <%# 右パネル %>
    <div style="padding: 1.5rem 2.5rem; display: flex; flex-direction: column; justify-content: center; gap: 0.85rem;">
      <div>
        <h1 style="font-size: 1.4rem; font-weight: 700; color: #9C6B7A; margin-bottom: 0.15rem; font-family: 'Plus Jakarta Sans', sans-serif;">新しいアカウントを作成</h1>
        <p style="font-size: 0.9rem; color: #514442; font-family: 'Plus Jakarta Sans', sans-serif;">感情の記録を、今日から始めよう。</p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "users/shared/error_messages", resource: resource %>

        <div class="field">
          <label style="font-size: 11px; font-weight: 600; color: #837472; text-transform: uppercase; letter-spacing: 0.06em; margin-left: 4px; font-family: 'Plus Jakarta Sans', sans-serif; display: flex; align-items: center; gap: 6px;">
            ユーザー名 <span class="form-required">必須</span>
          </label>
          <div class="input-row">
            <span class="mat-icon">person</span>
            <%= f.text_field :name, placeholder: "あなたのお名前", autocomplete: "name" %>
          </div>
        </div>

        <div class="field">
          <label style="font-size: 11px; font-weight: 600; color: #837472; text-transform: uppercase; letter-spacing: 0.06em; margin-left: 4px; font-family: 'Plus Jakarta Sans', sans-serif; display: flex; align-items: center; gap: 6px;">
            メールアドレス <span class="form-required">必須</span>
          </label>
          <div class="input-row">
            <span class="mat-icon">mail</span>
            <%= f.email_field :email, placeholder: "hello@feelog.com", autocomplete: "email" %>
          </div>
        </div>

        <div class="field">
          <div style="display: flex; justify-content: flex-start; gap: 0.5rem; align-items: center; margin-left: 4px;">
            <label style="font-size: 11px; font-weight: 600; color: #837472; text-transform: uppercase; letter-spacing: 0.06em; font-family: 'Plus Jakarta Sans', sans-serif; display: flex; align-items: center; gap: 6px;">
              パスワード <span class="form-required">必須</span>
            </label>
            <% if @minimum_password_length %>
              <span style="font-size: 11px; color: #837472; font-family: 'Plus Jakarta Sans', sans-serif;">（<%= @minimum_password_length %>文字以上）</span>
            <% end %>
          </div>
          <div class="input-row">
            <span class="mat-icon">lock</span>
            <%= f.password_field :password, placeholder: "••••••••", autocomplete: "new-password", id: "pw1" %>
            <button class="eye-btn" id="eye1" onclick="togglePw('pw1','eye1')" type="button">visibility_off</button>
          </div>
        </div>

        <div class="field">
          <label style="font-size: 11px; font-weight: 600; color: #837472; text-transform: uppercase; letter-spacing: 0.06em; margin-left: 4px; font-family: 'Plus Jakarta Sans', sans-serif; display: flex; align-items: center; gap: 6px;">
            パスワード（確認） <span class="form-required">必須</span>
          </label>
          <div class="input-row">
            <span class="mat-icon">lock</span>
            <%= f.password_field :password_confirmation, placeholder: "••••••••", autocomplete: "new-password", id: "pw2" %>
            <button class="eye-btn" id="eye2" onclick="togglePw('pw2','eye2')" type="button">visibility_off</button>
          </div>
        </div>

        <div class="terms-row">
          <%= f.check_box :terms_of_service, id: "terms" %>
          <label for="terms" style="font-size: 12px; color: #514442; line-height: 1.5; font-family: 'Plus Jakarta Sans', sans-serif;">
            <%= link_to '利用規約', terms_path, target: '_blank', style: 'color: #9C6B7A; text-decoration: underline; text-underline-offset: 2px;' %>と
            <%= link_to 'プライバシーポリシー', privacy_path, target: '_blank', style: 'color: #9C6B7A; text-decoration: underline; text-underline-offset: 2px;' %>に同意します。
          </label>
        </div>

        <%= f.submit "旅を始める", class: "submit-btn" %>
      <% end %>

      <div class="oauth-divider">
        <span>または</span>
      </div>

      <%= button_to "/users/auth/google_oauth2", method: :post, class: "google-btn", data: { turbo: false } do %>
        <svg class="google-icon" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
          <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
          <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
          <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
        </svg>
        Googleで登録
      <% end %>

      <p style="text-align: center; font-size: 0.9rem; color: #514442; font-family: 'Plus Jakarta Sans', sans-serif; margin-top: 0.5rem;">
        すでにアカウントをお持ちですか？
        <%= link_to 'ログインはこちら', new_user_session_path, style: 'color: #9C6B7A; font-weight: 600; text-decoration: underline; text-underline-offset: 3px;' %>
      </p>
    </div>

  </div>
</div>

<script>
function togglePw(inputId, btnId) {
  const input = document.getElementById(inputId);
  const btn = document.getElementById(btnId);
  if (input.type === 'password') {
    input.type = 'text';
    btn.textContent = 'visibility';
    btn.style.color = '#9C6B7A';
  } else {
    input.type = 'password';
    btn.textContent = 'visibility_off';
    btn.style.color = '#bfb3b1';
  }
}
</script>