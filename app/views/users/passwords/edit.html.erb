<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <h1 class="auth-title">パスワードの再設定</h1>
      <p class="auth-subtitle">新しいパスワードを設定して、<br>旅の続きを記録しましょう。</p>
    </div>

    <%= render "users/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.hidden_field :reset_password_token %>

      <div class="form-group">
        <label class="form-label">新しいパスワード</label>
        <div class="input-wrapper">
          <span class="material-symbols-outlined input-icon">lock</span>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              class: "form-input input-with-icon",
              placeholder: "6文字以上の半角英数字" %>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">パスワードの確認</label>
        <div class="input-wrapper">
          <span class="material-symbols-outlined input-icon">lock</span>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "form-input input-with-icon",
              placeholder: "もう一度入力してください" %>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit "パスワードを更新する", class: "btn-primary btn-full" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= link_to "ログイン画面に戻る", new_user_session_path, class: "auth-link" %>
    </div>
  </div>
</div>