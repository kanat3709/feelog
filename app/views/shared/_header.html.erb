<%# app/views/shared/_header.html.erb %>
<header class="feelog-header">
  <div class="header-inner">
    <%# ── ロゴ ── %>
    <%= link_to root_path, class: "header-logo" do %>
      <span class="logo-mark">✦</span>
      <span class="logo-text">Feelog</span>
    <% end %>

    <%# ── 右側：アイコン＋ドロップダウン ── %>
    <% if user_signed_in? %>
      <div class="header-user" data-controller="dropdown">
        <button class="user-icon-btn" data-action="click->dropdown#toggle" aria-expanded="false" aria-haspopup="true">
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, class: "user-avatar" %>
          <% else %>
            <span class="material-symbols-outlined user-avatar-icon">account_circle</span>
          <% end %>
          <span class="material-symbols-outlined chevron-icon">expand_more</span>
        </button>

        <nav class="dropdown-menu" data-dropdown-target="menu" role="menu" aria-label="ユーザーメニュー">
          <div class="dropdown-user-info">
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar, class: "dropdown-avatar" %>
            <% else %>
              <span class="material-symbols-outlined dropdown-avatar-icon">account_circle</span>
            <% end %>
            <span class="dropdown-username"><%= current_user.name %></span>
          </div>
          <hr class="dropdown-divider">
          <ul class="dropdown-list">
            <li>
              <%= link_to mypage_path, class: "dropdown-item", role: "menuitem" do %>
                <span class="material-symbols-outlined">home</span>
                マイページ
              <% end %>
            </li>
            <li>
              <%= link_to edit_user_path(current_user), class: "dropdown-item", role: "menuitem" do %>
                <span class="material-symbols-outlined">manage_accounts</span>
                プロフィール編集
              <% end %>
            </li>
            <li>
              <%= link_to wish_lists_path, class: "dropdown-item", role: "menuitem" do %>
                <span class="material-symbols-outlined">flag</span>
                行きたい！
              <% end %>
            </li>
            <li>
              <hr class="dropdown-divider">
              <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item dropdown-item--danger", role: "menuitem" do %>
                <span class="material-symbols-outlined">logout</span>
                ログアウト
              <% end %>
            </li>
          </ul>
        </nav>
      </div>
    <% else %>
      <div class="header-auth">
        <%= link_to "ログイン", new_user_session_path, class: "btn-primary-sm" %>
        <%= link_to "新規登録", new_user_registration_path, class: "btn-primary-sm" %>
      </div>
    <% end %>
  </div>
</header>