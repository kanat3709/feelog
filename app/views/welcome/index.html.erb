<%# ヒーローセクション %>
<section style="position: relative; min-height: 600px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
  <img src="https://images.unsplash.com/photo-1499002238440-d264edd596ec?w=1400&q=80" alt="lavender field" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"/>
  <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(30,15,20,0.25) 0%, rgba(30,15,20,0.45) 100%);"></div>
  <div style="position: relative; z-index: 1; text-align: center; padding: 2rem; max-width: 680px;">
    <h1 style="font-size: 3.2rem; font-weight: 700; letter-spacing: -0.03em; color: #9C6B7A; margin-bottom: 1rem; line-height: 1.2; text-shadow: 0 2px 20px rgba(255,255,255,0.3); font-family: 'Plus Jakarta Sans', sans-serif;">感情を記録し、<br/>自分を知ろう。</h1>
    <p style="font-size: 1.05rem; color: rgba(255,255,255,0.92); line-height: 1.8; margin-bottom: 2.5rem; text-shadow: 0 1px 8px rgba(0,0,0,0.3); font-family: 'Plus Jakarta Sans', sans-serif;">日々の気持ちを言葉にして残すことで、<br/>自分だけの感情の地図が生まれます。</p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <%= link_to '新規登録（無料）', new_user_registration_path, style: 'background: linear-gradient(to right, #f7c1bb, #cee5da); color: #754d49; font-size: 1rem; font-weight: 600; padding: 0.85rem 2rem; border-radius: 2rem; text-decoration: none; font-family: "Plus Jakarta Sans", sans-serif;' %>
      <%= link_to 'ログイン', new_user_session_path, style: 'background: linear-gradient(to right, #f7c1bb, #cee5da); color: #754d49; font-size: 1rem; font-weight: 600; padding: 0.85rem 2rem; border-radius: 2rem; text-decoration: none; font-family: "Plus Jakarta Sans", sans-serif;' %>
    </div>
  </div>
</section>

<%# 投稿例セクション %>
<section style="padding: 5rem 2rem;">
  <p style="font-size: 11px; font-weight: 600; color: #9C6B7A; text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem;">Your Story</p>
  <div style="text-align: center; margin-bottom: 3rem;">
    <h2 style="font-size: 1.9rem; font-weight: 700; color: #9C6B7A; letter-spacing: -0.02em; margin-bottom: 0.5rem; font-family: 'Plus Jakarta Sans', sans-serif;">あなたの感情を、記録しよう</h2>
    <p style="font-size: 0.95rem; color: #514442; line-height: 1.7; font-family: 'Plus Jakarta Sans', sans-serif;">写真・場所・感情タグで、その日の気持ちを残せます</p>
  </div>
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 960px; margin: 0 auto;">
    <div style="background: rgba(255,255,255,0.75); border-radius: 1rem; border: 1px solid rgba(255,255,255,0.7); box-shadow: 0 4px 24px rgba(125,84,79,0.07); overflow: hidden;">
      <img src="https://images.unsplash.com/photo-1522383225653-ed111181a951?w=400&q=80" alt="sakura" style="width: 100%; height: 150px; object-fit: cover; display: block;"/>
      <div style="padding: 1.25rem;">
        <div style="display: inline-flex; align-items: center; gap: 0.4rem; background: rgba(156,107,122,0.1); color: #9C6B7A; font-size: 11px; font-weight: 600; padding: 0.25rem 0.65rem; border-radius: 2rem; margin-bottom: 0.65rem; font-family: 'Plus Jakarta Sans', sans-serif;">😊 喜び</div>
        <h3 style="font-size: 0.95rem; font-weight: 600; color: #1b1c17; margin-bottom: 0.4rem; font-family: 'Plus Jakarta Sans', sans-serif;">桜を見に行った日</h3>
        <p style="font-size: 0.82rem; color: #514442; line-height: 1.6; font-family: 'Plus Jakarta Sans', sans-serif;">満開の桜の下で、心がふわっと軽くなった。来年も絶対来よう。</p>
        <p style="font-size: 10px; color: #837472; margin-top: 0.65rem; font-family: 'Plus Jakarta Sans', sans-serif;">📍 新宿御苑 · 2024.03.28</p>
      </div>
    </div>
    <div style="background: rgba(255,255,255,0.75); border-radius: 1rem; border: 1px solid rgba(255,255,255,0.7); box-shadow: 0 4px 24px rgba(125,84,79,0.07); overflow: hidden;">
      <img src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=400&q=80" alt="night walk" style="width: 100%; height: 150px; object-fit: cover; display: block;"/>
      <div style="padding: 1.25rem;">
        <div style="display: inline-flex; align-items: center; gap: 0.4rem; background: rgba(156,107,122,0.1); color: #9C6B7A; font-size: 11px; font-weight: 600; padding: 0.25rem 0.65rem; border-radius: 2rem; margin-bottom: 0.65rem; font-family: 'Plus Jakarta Sans', sans-serif;">😌 穏やか</div>
        <h3 style="font-size: 0.95rem; font-weight: 600; color: #1b1c17; margin-bottom: 0.4rem; font-family: 'Plus Jakarta Sans', sans-serif;">夜の散歩</h3>
        <p style="font-size: 0.82rem; color: #514442; line-height: 1.6; font-family: 'Plus Jakarta Sans', sans-serif;">静かな夜道を一人で歩いた。頭の中が少しずつ整理されていく感覚。</p>
        <p style="font-size: 10px; color: #837472; margin-top: 0.65rem; font-family: 'Plus Jakarta Sans', sans-serif;">📍 代々木公園 · 2024.04.02</p>
      </div>
    </div>
    <div style="background: rgba(255,255,255,0.75); border-radius: 1rem; border: 1px solid rgba(255,255,255,0.7); box-shadow: 0 4px 24px rgba(125,84,79,0.07); overflow: hidden;">
      <img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=400&q=80" alt="cafe" style="width: 100%; height: 150px; object-fit: cover; display: block;"/>
      <div style="padding: 1.25rem;">
        <div style="display: inline-flex; align-items: center; gap: 0.4rem; background: rgba(156,107,122,0.1); color: #9C6B7A; font-size: 11px; font-weight: 600; padding: 0.25rem 0.65rem; border-radius: 2rem; margin-bottom: 0.65rem; font-family: 'Plus Jakarta Sans', sans-serif;">🌟 感動</div>
        <h3 style="font-size: 0.95rem; font-weight: 600; color: #1b1c17; margin-bottom: 0.4rem; font-family: 'Plus Jakarta Sans', sans-serif;">カフェでの午後</h3>
        <p style="font-size: 0.82rem; color: #514442; line-height: 1.6; font-family: 'Plus Jakarta Sans', sans-serif;">好きな本を読みながら過ごした。こういう時間が一番大切だと気づいた。</p>
        <p style="font-size: 10px; color: #837472; margin-top: 0.65rem; font-family: 'Plus Jakarta Sans', sans-serif;">📍 渋谷 · 2024.04.10</p>
      </div>
    </div>
  </div>
</section>

<%# 感情タグセクション %>
<section style="background: linear-gradient(135deg, rgba(247,193,187,0.12) 0%, rgba(206,229,218,0.12) 100%); padding: 5rem 2rem;">
  <p style="font-size: 11px; font-weight: 600; color: #9C6B7A; text-transform: uppercase; letter-spacing: 0.1em; text-align: center; margin-bottom: 0.75rem;">Emotion Tags</p>
  <div style="text-align: center; margin-bottom: 2rem;">
    <h2 style="font-size: 1.9rem; font-weight: 700; color: #9C6B7A; letter-spacing: -0.02em; margin-bottom: 0.5rem; font-family: 'Plus Jakarta Sans', sans-serif;">感情をタグで記録</h2>
    <p style="font-size: 0.95rem; color: #514442; line-height: 1.7; font-family: 'Plus Jakarta Sans', sans-serif;">あらかじめ用意された感情タグで、今の気持ちをかんたんに記録できます</p>
  </div>
  <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; max-width: 600px; margin: 0 auto;">
    <div style="display: flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.85); border: 1px solid rgba(156,107,122,0.15); color: #514442; font-size: 0.88rem; font-weight: 500; padding: 0.5rem 1.1rem; border-radius: 2rem; font-family: 'Plus Jakarta Sans', sans-serif;">😊 喜び</div>
    <div style="display: flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.85); border: 1px solid rgba(156,107,122,0.15); color: #514442; font-size: 0.88rem; font-weight: 500; padding: 0.5rem 1.1rem; border-radius: 2rem; font-family: 'Plus Jakarta Sans', sans-serif;">😢 悲しみ</div>
    <div style="display: flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.85); border: 1px solid rgba(156,107,122,0.15); color: #514442; font-size: 0.88rem; font-weight: 500; padding: 0.5rem 1.1rem; border-radius: 2rem; font-family: 'Plus Jakarta Sans', sans-serif;">😌 穏やか</div>
    <div style="display: flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.85); border: 1px solid rgba(156,107,122,0.15); color: #514442; font-size: 0.88rem; font-weight: 500; padding: 0.5rem 1.1rem; border-radius: 2rem; font-family: 'Plus Jakarta Sans', sans-serif;">🌟 感動</div>
    <div style="display: flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.85); border: 1px solid rgba(156,107,122,0.15); color: #514442; font-size: 0.88rem; font-weight: 500; padding: 0.5rem 1.1rem; border-radius: 2rem; font-family: 'Plus Jakarta Sans', sans-serif;">😮 驚き</div>
  </div>
</section>

<%# CTAセクション %>
<section style="padding: 6rem 2rem; text-align: center; position: relative; overflow: hidden;">
  <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 400px; background: rgba(247,193,187,0.2); border-radius: 50%; filter: blur(60px); pointer-events: none;"></div>
  <div style="position: relative; z-index: 1; max-width: 520px; margin: 0 auto;">
    <h2 style="font-size: 2rem; font-weight: 700; color: #9C6B7A; letter-spacing: -0.02em; margin-bottom: 1rem; line-height: 1.3; font-family: 'Plus Jakarta Sans', sans-serif;">今日から、感情を<br/>記録しよう。</h2>
    <p style="font-size: 0.95rem; color: #514442; line-height: 1.8; margin-bottom: 2rem; font-family: 'Plus Jakarta Sans', sans-serif;">無料で始められます。あなただけの感情の地図を、今日から作り始めましょう。</p>
    <%= link_to '新規登録（無料）', new_user_registration_path, style: 'background: linear-gradient(to right, #f7c1bb, #cee5da); color: #754d49; font-size: 1.05rem; font-weight: 600; padding: 1rem 2.5rem; border-radius: 2rem; text-decoration: none; font-family: "Plus Jakarta Sans", sans-serif;' %>
  </div>
</section>